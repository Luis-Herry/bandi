{
  "name": "anime-tracker",
  "version": "0.1.7",
  "description": "Windows local-first anime tracker, downloader, and personal media center.",
  "author": "Luis-Herry",
  "license": "GPL-3.0-only",
  "private": true,
  "main": "desktop/main.cjs",
  "homepage": "https://github.com/Luis-Herry/bandi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luis-Herry/bandi.git"
  },
  "bugs": {
    "url": "https://github.com/Luis-Herry/bandi/issues"
  },
  "keywords": [
    "anime",
    "electron",
    "local-first",
    "media-center",
    "rss",
    "qbittorrent"
  ],
  "scripts": {
    "dev": "node scripts/run-local-next.mjs dev",
    "build": "next build",
    "desktop:prepare": "node scripts/prepare-standalone.mjs && node scripts/generate-third-party-licenses.mjs",
    "media:verify-ffmpeg": "node scripts/verify-ffmpeg-runtime.mjs",
    "media:source-offer": "node --use-env-proxy scripts/prepare-ffmpeg-source-offer.mjs",
    "desktop:start": "node scripts/desktop-dev-start.mjs",
    "desktop:check-build": "node scripts/desktop-dev-start.mjs --check",
    "desktop:pack": "npm run build && npm run desktop:prepare && electron-builder --dir",
    "desktop:dist": "npm run build && npm run desktop:prepare && electron-builder --win",
    "desktop:dist:local-ffmpeg": "npm run media:verify-ffmpeg && npm run build && npm run desktop:prepare && electron-builder --config desktop/electron-builder-local.cjs --win",
    "local-server:assets:x64": "node scripts/prepare-macos-assets.mjs --arch=x64",
    "local-server:assets:arm64": "node scripts/prepare-macos-assets.mjs --arch=arm64",
    "local-server:dist:x64": "node scripts/build-macos-local.mjs --arch=x64",
    "local-server:dist:arm64": "node scripts/build-macos-local.mjs --arch=arm64",
    "local-server:dist:x64:local-ffmpeg": "node scripts/build-macos-local.mjs --arch=x64 --local-ffmpeg",
    "local-server:dist:arm64:local-ffmpeg": "node scripts/build-macos-local.mjs --arch=arm64 --local-ffmpeg",
    "local-server:smoke": "node scripts/smoke-local-web.mjs",
    "test": "tsx --test tests/*.test.ts",
    "start": "node scripts/run-local-next.mjs start",
    "db:push": "drizzle-kit push --force",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "node-cron": "^4.2.1",
    "opencc-js": "^1.3.1",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "5.3.0",
    "js-yaml": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "$postcss",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  },
  "build": {
    "appId": "cn.luis.anime-tracker.desktop",
    "productName": "追番中心",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "npmRebuild": false,
    "files": [
      "desktop/**/*",
      "runtime/**/*",
      ".next/standalone/**/*",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "THIRD_PARTY_LICENSES.txt",
      "ASSETS.md",
      "package.json"
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "Luis-Herry",
        "repo": "bandi",
        "channel": "latest",
        "releaseType": "draft"
      }
    ],
    "extraResources": [
      {
        "from": "vendor/qbittorrent",
        "to": "vendor/qbittorrent",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/node",
        "to": "vendor/node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "desktop/assets/app-icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "desktop/assets/app-icon.ico",
      "uninstallerIcon": "desktop/assets/app-icon.ico",
      "installerHeaderIcon": "desktop/assets/app-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "追番中心",
      "artifactName": "Bandi-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Bandi-${version}-${arch}-portable.${ext}"
    }
  }
}
